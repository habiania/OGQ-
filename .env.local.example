# 둘 중 하나 이상 채우면 됩니다. UI에서 OpenAI/Gemini 중 선택해서 사용.
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=...

# 기본 제공자 (openai | gemini)
DEFAULT_IMAGE_PROVIDER=openai

# 암호 잠금(배포 시). 둘 다 채우면 사이트 전체가 기본 인증으로 잠김.
# 로컬에서 비워두면 인증 없이 통과.
BASIC_AUTH_USER=
BASIC_AUTH_PASS=

# 위탁판매 도구 (네이버 개발자센터: 검색 + 데이터랩 쇼핑인사이트 / 도매매 OpenAPI)
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
DOMEGGOOK_API_KEY=

# KDP 북 스튜디오 (선택) — 넣으면 자동 활성화
# PERPLEXITY_API_KEY: 챕터 사실조사·출처 수집 (없으면 조사 생략하고 집필)
# OPENAI_API_KEY(위 이미지용과 동일): 챕터 삽화 생성 (충전 필요, 없으면 글만)
PERPLEXITY_API_KEY=
